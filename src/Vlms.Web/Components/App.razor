<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Vlms.Web.styles.css"]" />
    <!-- PWA installability (adr/0001-technology-stack.md: "Blazor Web App ..., PWA-installable")
         — manifest.json/icons/icon.svg are plain wwwroot paths, not run through the Assets
         fingerprinting helper above, since nothing in the app references them from Razor markup
         besides this link (see openwiki/web.md). -->
    <link rel="manifest" href="manifest.json" />
    <meta name="theme-color" content="#1f2937" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('service-worker.js');
        }
    </script>
</body>

</html>
